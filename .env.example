# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Sender Gmail address
export GMAIL_EMAIL=you@gmail.com

# Gmail app password (generated at myaccount.google.com/apppasswords)
# Spaces are stripped automatically — copy it exactly as shown by Google.
export GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

# Recipient email address for campsite notifications
export NOTIFY_EMAIL=you@example.com
